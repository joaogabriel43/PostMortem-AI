# Spring Boot DataSource (used by application.yml)
DATABASE_URL=jdbc:postgresql://localhost:5434/postmortemai
DATABASE_URL_DEV=jdbc:p6spy:postgresql://localhost:5434/postmortemai
DATABASE_USERNAME=postmortemai
DATABASE_PASSWORD=changeme

# OpenAI (Sprint 03+)
OPENAI_API_KEY=sk-...
